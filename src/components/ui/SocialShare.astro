---
interface Props {
  url?: string;
  title?: string;
  class?: string;
  orientation?: 'horizontal' | 'vertical';
  showLabels?: boolean;
}

const {
  url = Astro.url.href,
  title = '',
  class: className = '',
  orientation = 'horizontal',
  showLabels = false,
} = Astro.props as Props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const directionClass =
  orientation === 'vertical' ? 'flex-col items-center' : 'flex-row items-center';
---

<div
  class={`flex gap-2 ${directionClass} ${className}`}
  aria-label="Compartir"
  data-social-share
  data-share-title={title}
>
  <a
    href={`https://x.com/intent/post?url=${encodedUrl}&text=${encodedTitle}`}
    class="flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2 dark:hover:text-white"
    title="Compartir en X"
    aria-label="Compartir en X"
    target="_blank"
    rel="noopener noreferrer"
    data-share-network="x"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path>
    </svg>
    {showLabels && <span class="text-sm font-medium">X</span>}
  </a>

  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    class="flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-[#0A66C2] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2"
    title="Compartir en LinkedIn"
    aria-label="Compartir en LinkedIn"
    target="_blank"
    rel="noopener noreferrer"
    data-share-network="linkedin"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"></path>
    </svg>
    {showLabels && <span class="text-sm font-medium">LinkedIn</span>}
  </a>

  <a
    href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
    class="flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-[#1877F2] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2"
    title="Compartir en Facebook"
    aria-label="Compartir en Facebook"
    target="_blank"
    rel="noopener noreferrer"
    data-share-network="facebook"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073Z"></path>
    </svg>
    {showLabels && <span class="text-sm font-medium">Facebook</span>}
  </a>

  <div class="h-4 w-px bg-border-default mx-1 hidden sm:block"></div>

  <button
    type="button"
    aria-label="Copiar enlace"
    class="inline-flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2"
    title="Copiar enlace"
    data-copy-share
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
    </svg>
    {showLabels && <span class="text-sm font-medium" data-copy-label>Copiar</span>}
  </button>
</div>

<script is:inline>
  (() => {
    window.__ajeduSocialShareInit =
      window.__ajeduSocialShareInit ||
      (() => {
        document.querySelectorAll('[data-social-share]').forEach((root) => {
          if (root.dataset.shareBound === 'true') return;
          root.dataset.shareBound = 'true';

          const url = window.location.href;
          const title = root.getAttribute('data-share-title') || document.title;
          const encodedUrl = encodeURIComponent(url);
          const encodedTitle = encodeURIComponent(title);

          root
            .querySelector('[data-share-network="x"]')
            ?.setAttribute(
              'href',
              `https://x.com/intent/post?url=${encodedUrl}&text=${encodedTitle}`,
            );
          root
            .querySelector('[data-share-network="linkedin"]')
            ?.setAttribute('href', `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`);
          root
            .querySelector('[data-share-network="facebook"]')
            ?.setAttribute('href', `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`);

          const copyButton = root.querySelector('[data-copy-share]');
          const copyLabel = root.querySelector('[data-copy-label]');
          const defaultLabel = copyLabel?.textContent || 'Copiar';

          copyButton?.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(url);
              copyButton.setAttribute('title', 'Enlace copiado');
              if (copyLabel) copyLabel.textContent = 'Copiado';
              window.setTimeout(() => {
                copyButton.setAttribute('title', 'Copiar enlace');
                if (copyLabel) copyLabel.textContent = defaultLabel;
              }, 1800);
            } catch {}
          });
        });
      });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', window.__ajeduSocialShareInit, { once: true });
    } else {
      window.__ajeduSocialShareInit();
    }
  })();
</script>
