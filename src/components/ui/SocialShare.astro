---
interface Props {
  url?: string;
  title?: string;
  class?: string;
  orientation?: 'horizontal' | 'vertical';
  showLabels?: boolean;
}

const {
  url = Astro.url.href,
  title = '',
  class: className = '',
  orientation = 'horizontal',
  showLabels = false,
} = Astro.props as Props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const directionClass =
  orientation === 'vertical' ? 'flex-col items-center' : 'flex-row items-center';
---

<div
  class={`flex gap-2 ${directionClass} ${className}`}
  aria-label="Compartir"
  data-social-share
  data-share-title={title}
>
  <a
    href={`https://x.com/intent/post?url=${encodedUrl}&text=${encodedTitle}`}
    class="flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2 dark:hover:text-white"
    title="Compartir en X"
    aria-label="Compartir en X"
    target="_blank"
    rel="noopener noreferrer"
    data-share-network="x"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path>
    </svg>
    {showLabels && <span class="text-sm font-medium">X</span>}
  </a>

  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    class="flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-[#0A66C2] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2"
    title="Compartir en LinkedIn"
    aria-label="Compartir en LinkedIn"
    target="_blank"
    rel="noopener noreferrer"
    data-share-network="linkedin"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"></path>
    </svg>
    {showLabels && <span class="text-sm font-medium">LinkedIn</span>}
  </a>

  <a
    href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
    class="flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-[#1877F2] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2"
    title="Compartir en Facebook"
    aria-label="Compartir en Facebook"
    target="_blank"
    rel="noopener noreferrer"
    data-share-network="facebook"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073Z"></path>
    </svg>
    {showLabels && <span class="text-sm font-medium">Facebook</span>}
  </a>

  <a
    href={`https://wa.me/?text=${encodedTitle}%20${encodedUrl}`}
    class="flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-[#25D366] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2"
    title="Compartir por WhatsApp"
    aria-label="Compartir por WhatsApp"
    target="_blank"
    rel="noopener noreferrer"
    data-share-network="whatsapp"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.52 3.48A11.86 11.86 0 0 0 12.05 0C5.47 0 .1 5.36.1 11.94c0 2.1.55 4.16 1.6 5.97L0 24l6.24-1.64a11.94 11.94 0 0 0 5.8 1.48h.01c6.58 0 11.94-5.36 11.94-11.94 0-3.19-1.24-6.18-3.47-8.42ZM12.05 21.8h-.01a9.88 9.88 0 0 1-5.04-1.38l-.36-.21-3.7.97.99-3.61-.23-.37a9.84 9.84 0 0 1-1.5-5.26c0-5.46 4.44-9.9 9.91-9.9 2.64 0 5.13 1.03 7 2.9a9.83 9.83 0 0 1 2.9 7c0 5.46-4.45 9.86-9.96 9.86Zm5.43-7.39c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.48-1.75-1.65-2.05-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.49s1.07 2.89 1.22 3.09c.15.2 2.11 3.22 5.11 4.52.71.31 1.27.49 1.7.63.71.23 1.36.2 1.88.12.57-.09 1.76-.72 2.01-1.42.25-.7.25-1.29.17-1.42-.08-.13-.27-.2-.57-.35Z"></path>
    </svg>
    {showLabels && <span class="text-sm font-medium">WhatsApp</span>}
  </a>

  <div class="h-4 w-px bg-border-default mx-1 hidden sm:block"></div>

  <span class="relative inline-flex">
    <button
      type="button"
      aria-label="Haz clic para copiar enlace"
      class="inline-flex items-center gap-2 rounded-lg p-2 text-text-secondary transition-colors hover:bg-bg-secondary hover:text-text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2"
      title="Haz clic para copiar enlace"
      data-copy-share
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
      </svg>
      {showLabels && <span class="text-sm font-medium" data-copy-label>Copiar enlace</span>}
    </button>
    <span
      class="pointer-events-none absolute left-1/2 top-full z-10 mt-2 -translate-x-1/2 whitespace-nowrap rounded-lg border border-border-default bg-bg-elevated px-3 py-1.5 text-xs font-semibold text-text-primary opacity-0 shadow-lg transition-opacity"
      data-copy-status
      aria-live="polite"
    >
      Enlace copiado
    </span>
  </span>
</div>

<script is:inline>
  (() => {
    window.__ajeduSocialShareInit =
      window.__ajeduSocialShareInit ||
      (() => {
        document.querySelectorAll('[data-social-share]').forEach((root) => {
          if (root.dataset.shareBound === 'true') return;
          root.dataset.shareBound = 'true';

          const url = window.location.href;
          const title = root.getAttribute('data-share-title') || document.title;
          const encodedUrl = encodeURIComponent(url);
          const encodedTitle = encodeURIComponent(title);

          root
            .querySelector('[data-share-network="x"]')
            ?.setAttribute(
              'href',
              `https://x.com/intent/post?url=${encodedUrl}&text=${encodedTitle}`,
            );
          root
            .querySelector('[data-share-network="linkedin"]')
            ?.setAttribute('href', `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`);
          root
            .querySelector('[data-share-network="facebook"]')
            ?.setAttribute('href', `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`);
          root
            .querySelector('[data-share-network="whatsapp"]')
            ?.setAttribute('href', `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`);

          const copyButton = root.querySelector('[data-copy-share]');
          const copyLabel = root.querySelector('[data-copy-label]');
          const copyStatus = root.querySelector('[data-copy-status]');
          const defaultLabel = copyLabel?.textContent || 'Copiar enlace';

          const copyText = async (text) => {
            if (navigator.clipboard?.writeText) {
              await navigator.clipboard.writeText(text);
              return;
            }

            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.setAttribute('readonly', '');
            textarea.style.position = 'fixed';
            textarea.style.top = '-9999px';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            const copied = document.execCommand('copy');
            textarea.remove();
            if (!copied) throw new Error('No se pudo copiar el enlace');
          };

          const showCopyStatus = (message) => {
            if (!copyStatus) return;
            copyStatus.textContent = message;
            copyStatus.classList.remove('opacity-0');
            copyStatus.classList.add('opacity-100');
          };

          const resetCopyStatus = () => {
            copyButton?.setAttribute('title', 'Haz clic para copiar enlace');
            copyButton?.setAttribute('aria-label', 'Haz clic para copiar enlace');
            if (copyLabel) copyLabel.textContent = defaultLabel;
            copyStatus?.classList.remove('opacity-100');
            copyStatus?.classList.add('opacity-0');
          };

          copyButton?.addEventListener('click', async () => {
            try {
              await copyText(url);
              copyButton.setAttribute('title', 'Enlace copiado');
              copyButton.setAttribute('aria-label', 'Enlace copiado');
              if (copyLabel) copyLabel.textContent = 'Enlace copiado';
              showCopyStatus('Enlace copiado');
              window.setTimeout(resetCopyStatus, 1800);
            } catch {
              copyButton.setAttribute('title', 'No se pudo copiar');
              copyButton.setAttribute('aria-label', 'No se pudo copiar');
              if (copyLabel) copyLabel.textContent = 'No se pudo copiar';
              showCopyStatus('No se pudo copiar');
              window.setTimeout(resetCopyStatus, 2200);
            }
          });
        });
      });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', window.__ajeduSocialShareInit, { once: true });
    } else {
      window.__ajeduSocialShareInit();
    }
  })();
</script>
