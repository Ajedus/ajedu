---
import Layout from '../layouts/Layout.astro';
import { pageSEO, company } from '../config/site';
import { LegalHero } from '../components/sections/LegalHero';
import { LegalContent } from '../components/sections/LegalContent';
import { privacyData } from '../data/legal';

const seo = pageSEO.privacy;
---

<Layout title={seo.title} description={seo.description}>
  <LegalHero title={privacyData.title} lastUpdated={privacyData.lastUpdated} />

  <LegalContent sections={privacyData.sections} />
</Layout>
