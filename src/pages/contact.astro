---
import Layout from '../layouts/Layout.astro';
import { pageSEO } from '../config/site';
import { ContactHero } from '../components/sections/ContactHero';
import { Container } from '../components/ui/Container';
import { Section } from '../components/ui/Section';

const seo = pageSEO.contact;
const googleFormEmbedUrl =
  'https://docs.google.com/forms/d/e/1FAIpQLSfng41FKAHABS4M9reJxMbxEdehKZziRzCI-ZUNJld5AGkqZg/viewform?embedded=true';
---

<Layout title={seo.title} description={seo.description}>
  {/* 1. Contact Hero */}
  <ContactHero />

  <Section id="quiero-ser-integrante" background="muted" padding="xl">
    <Container size="narrow">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <p class="mb-4 text-sm font-bold uppercase tracking-[0.22em] text-primary-400">
          Comunidad ajEdu
        </p>
        <h2 class="text-4xl font-extrabold tracking-tight text-text-primary sm:text-5xl">
          Quiero ser <span class="text-primary-400">integrante</span>
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-text-secondary">
          Si compartes recursos, experiencias, proyectos o investigacion vinculada al ajedrez
          educativo, puedes solicitar aqui tu incorporacion a la red ajEdu.
        </p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-border-default bg-bg-primary shadow-2xl">
        <iframe
          src={googleFormEmbedUrl}
          class="h-[3300px] w-full border-0 sm:h-[3000px] lg:h-[2734px]"
          title="Formulario para ser integrante de ajEdu"
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
          sandbox="allow-forms allow-popups allow-same-origin allow-scripts"
        >
          Cargando formulario...
        </iframe>
      </div>
    </Container>
  </Section>
</Layout>
