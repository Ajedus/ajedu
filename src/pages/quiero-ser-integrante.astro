---
import Layout from '../layouts/Layout.astro';

const target = '/contact/#quiero-ser-integrante';
---

<Layout
  title="Quiero ser integrante"
  description="Solicitud para formar parte de la comunidad ajEdu."
  headerVariant="none"
  footerVariant="none"
>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <script is:inline set:html={`window.location.replace(${JSON.stringify(target)});`} />
  </Fragment>

  <div class="min-h-screen bg-bg-primary px-6 py-16 text-center text-text-primary">
    <p>Redirigiendo al formulario de ajEdu...</p>
    <p class="mt-4">
      <a class="text-primary-400 underline" href={target}>Ir al formulario</a>
    </p>
  </div>
</Layout>
